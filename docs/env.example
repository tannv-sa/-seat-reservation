# ============================================================
# Salin file này thành .env.local và điền giá trị thực
# KHÔNG commit file .env.local lên Git
# ============================================================

# Supabase — lấy từ Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stripe — lấy từ Stripe Dashboard → Developers → API keys
# Dùng test keys (sk_test_..., pk_test_...) cho development
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Webhook Secret — lấy sau khi chạy `stripe listen`
# hoặc từ Stripe Dashboard → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret — tự đặt một chuỗi ngẫu nhiên để bảo vệ endpoint
CRON_SECRET=your-random-secret-here
